<odoo>
    <record id="view_tarea_list" model="ir.ui.view">
        <field name="name">practica.tarea.list</field>
        <field name="model">practica.tarea</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="fecha_limite"/>
                <field name="hecho"/>
            </list>
        </field>
    </record>

    <record id="view_tarea_form" model="ir.ui.view">
        <field name="name">practica.tarea.form</field>
        <field name="model">practica.tarea</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="descripcion"/>
                        <field name="fecha_limite"/>
                        <field name="hecho"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tarea" model="ir.actions.act_window">
        <field name="name">Tareas</field>
        <field name="res_model">practica.tarea</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tarea_root" name="Práctica Tareas" sequence="10"/>
    <menuitem id="menu_tarea" name="Tareas" parent="menu_tarea_root" action="action_tarea"/>
</odoo>
